# ─── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://ses_user:ses_password@localhost:5432/ses_automator
POSTGRES_USER=ses_user
POSTGRES_PASSWORD=ses_password
POSTGRES_DB=ses_automator
POSTGRES_PORT=5432

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=8h

# ─── Microsoft Graph API ───────────────────────────────────────────────────────
# GRAPH_MODE controls authentication strategy:
#   personal → Device Code Flow (PublicClientApplication)  — uses /consumers authority
#   org      → Client Credentials Flow (ConfidentialClientApplication) — uses /{TENANT_ID}
#
# Migration from personal → org:
#   1. Set GRAPH_MODE=org
#   2. Set TENANT_ID to your Tullow Azure AD tenant ID
#   3. Set CLIENT_SECRET to the app registration secret
#   4. Set USER_EMAIL to the shared CE mailbox address
#   No code changes required — everything else reads these four variables.

GRAPH_MODE=personal

CLIENT_ID=your_azure_app_client_id
TENANT_ID=consumers
CLIENT_SECRET=
USER_EMAIL=

# ─── Webhook ───────────────────────────────────────────────────────────────────
# Public HTTPS URL where Graph will POST change notifications.
# Local dev: run `ngrok http 4000` and set this to the https forwarding URL + /api/emails/webhook
# Production: set to your deployed backend URL + /api/emails/webhook
NOTIFICATION_URL=https://your-ngrok-or-prod-url.ngrok-free.app/api/emails/webhook
WEBHOOK_CLIENT_STATE=invoice-automation-prod

# ─── Storage ───────────────────────────────────────────────────────────────────
# STORAGE_MODE controls where files are saved:
#   local → uploads/ directory (development)
#   azure → Azure Blob Storage (production)
STORAGE_MODE=local
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=ses-documents

# ─── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
